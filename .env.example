# Server
# Use production for a self-hosted instance behind HTTPS.
APP_ENV=development
HOST=0.0.0.0
PORT=8080
SELF_URL=http://localhost:8080
ALLOWED_CORS_ORIGIN=http://localhost:5173

# Persistent database; PostgreSQL is required for all durable state.
DATABASE_URL=postgresql://user:password@localhost:5432/autoresearch

# Single-account console access.
# Set a long random value before exposing the service.
ACCESS_PASSPHRASE=change-me
ACCESS_SESSION_COOKIE_NAME=single_account_session
ACCESS_SESSION_MAX_AGE_SECONDS=604800

# Ideavibes auth service placeholders. The current self-hosted console uses
# ACCESS_PASSPHRASE, but keep these set when the platform provisions them.
MCTAI_AUTH_URL=https://auth.mctai.app
MCTAI_AUTH_APP_TOKEN=app_token_here
MCTAI_AUTH_JWKS_URL=https://auth.mctai.app/.well-known/jwks.json

# Ideavibes email service; optional unless a future workflow sends mail.
MCTAI_EMAIL_URL=
MCTAI_EMAIL_APP_TOKEN=

# Model provider BYO key settings.
# You can also configure model credentials later in the protected console.
MODEL_PROVIDER=openai
MODEL_BASE_URL=https://api.openai.com/v1
MODEL_API_KEY=
MODEL_DEFAULT_MODEL=gpt-4.1-mini
MODEL_REQUEST_TIMEOUT_SECONDS=60

# Object storage; required for experiment outputs, LaTeX, PDFs, logs, and figures.
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_REGION=auto
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
OBJECT_STORAGE_PREFIX=autoresearch/

# External data sources.
ARXIV_API_URL=https://export.arxiv.org/api/query
SEMANTIC_SCHOLAR_API_URL=https://api.semanticscholar.org/graph/v1
GITHUB_API_URL=https://api.github.com
PAPERS_WITH_CODE_API_URL=https://paperswithcode.com/api/v1
SOURCE_CONNECTORS_ENABLED=arxiv,semantic_scholar,github,papers_with_code
SOURCE_REQUEST_TIMEOUT_SECONDS=30
SOURCE_MIN_INTERVAL_SECONDS=1
SOURCE_USER_AGENT=autoresearch/0.1
SEMANTIC_SCHOLAR_API_KEY=
OPENALEX_EMAIL=
GITHUB_TOKEN=

# Discovery scheduling; interval 0 disables periodic discovery.
DISCOVERY_DEFAULT_QUERY=machine learning
DISCOVERY_DEFAULT_LIMIT=10
DISCOVERY_INTERVAL_SECONDS=0
